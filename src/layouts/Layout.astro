---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	schema?: any;
}

const {
	title,
	description = "Logistics Gurukul - The #1 Logistics Institute in Kerala.",
	schema,
} = Astro.props;

import WhatsAppFloater from "../components/WhatsAppFloater";
import SEO from "../components/SEO.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<SEO title={title} description={description} schema={schema} />
		<slot name="head" />
		<!-- Google Tag Manager -->
		<script is:inline>
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != "dataLayer" ? "&l=" + l : "";
				j.async = true;
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", "GTM-5WKNKNTQ");
		</script>
		<!-- End Google Tag Manager -->
	</head>
	<body
		class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-orange-500 selection:text-white"
	>
		<!-- Google Tag Manager (noscript) -->
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-5WKNKNTQ"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- End Google Tag Manager (noscript) -->
		<slot />
		<WhatsAppFloater client:load />
	</body>
</html>
