---
export const prerender = false;

import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import ContactCTA from "../components/ContactCTA";
import ImageGallery from "../components/ImageGallery";
import { supabase } from "../lib/supabase";

// Features are still read from the markdown content collection until
// a Supabase editor for them ships.
const featureEntries = await getCollection(
  "infrastructure-features",
  ({ data }) => !data.draft,
);
const features = featureEntries
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    points: entry.data.points,
    align: entry.data.align,
    theme: entry.data.theme,
    image: entry.data.image,
    order: entry.data.order,
  }))
  .sort((a, b) => a.order - b.order);

// Gallery images come from Supabase so admins can upload without a rebuild.
const { data: galleryRows } = await supabase
  .from("infrastructure_gallery")
  .select('id, image, alt, "order"')
  .order("order", { ascending: true })
  .order("created_at", { ascending: true });

const galleryImages = (galleryRows ?? []).map((r) => ({
  id: r.id,
  src: r.image,
  alt: r.alt,
  order: r.order,
}));
---

<Layout
  title="Industry-Standard Learning Infrastructure Built for Real Logistics Careers| Logistics Gurukul"
  description="Explore the state-of-the-art facilities at Logistics Gurukul, including Smart Classrooms, Simulation Labs, and our comprehensive Library."
>
  <Navbar client:load />
  
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center bg-[#050505] overflow-hidden pt-20">
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0 z-0">
        {/* CLIENT_IMAGE_HERO_BG */}
        <img
          src="/port-img-scaled.jpg"
          alt="Infrastructure Background"
          class="w-full h-full object-cover opacity-60"
        />
        <div class="absolute inset-0 bg-blue-500/10 mix-blend-overlay"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-[#050505]"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10 text-center">
        <div class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-500/20 to-blue-500/5 border border-blue-500/30 rounded-full px-4 py-1.5 mb-8 backdrop-blur-md">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-400"></span>
            </span>
            <span class="text-blue-400 text-xs font-bold tracking-widest uppercase">Campus & Facilities</span>
        </div>

        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-6 font-heading tracking-tight leading-tight">
          Industry-Standard Learning Infrastructure <br class="hidden lg:block"/> Built for <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-white">Real Logistics Careers</span>
        </h1>
        
        <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed border-l-2 border-blue-500 pl-6 text-left md:text-center md:border-l-0 md:border-none">
          Designed to inspire learning and innovation. Experience a campus built for the future of logistics education.
        </p>
      </div>
    </section>

    <!-- Feature Sections (Zig-Zag) -->
    {features.map((feature, index) => (
      <section class={`py-20 md:py-24 ${feature.theme === 'dark' ? 'bg-[#0f0f14] text-white' : 'bg-slate-50 text-slate-900'}`}>
        <div class="container mx-auto px-6">
          <div class={`flex flex-col gap-12 lg:gap-20 items-center ${feature.align === 'left' ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
            
             <!-- Image Content -->
            <div class="w-full lg:w-1/2 order-first">
              <div class="relative group rounded-3xl overflow-hidden shadow-2xl border border-white/5">
                <div class="absolute inset-0 bg-blue-600/10 group-hover:bg-transparent transition-colors duration-500 z-10 w-full h-full"></div>
                
                <div class="aspect-[4/3] bg-slate-800 relative flex items-center justify-center overflow-hidden w-full">
                   {/* CLIENT_IMAGE_${feature.placeholderId} */}
                   <img 
                      src={feature.image || `https://placehold.co/800x600/1e293b/ffffff?text=${feature.title.replace(/ /g, '+')}`} 
                      alt={feature.title} 
                      class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" 
                    />
                </div>
                
                {/* Decorative float for Dark Theme items */}
                {feature.theme === 'dark' && (
                    <div class="absolute bottom-6 left-6 right-6 bg-slate-900/90 backdrop-blur-xl p-4 rounded-xl border border-slate-700 shadow-lg translate-y-2 opacity-90 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                        <div class="flex items-center gap-3">
                            <div class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></div>
                            <span class="text-sm font-mono text-slate-300">Active Facility Status: <span class="text-green-400 font-bold">Operational</span></span>
                        </div>
                    </div>
                )}
              </div>
            </div>

            <!-- Text Content -->
            <div class="w-full lg:w-1/2">
              <div class="flex items-center gap-2 mb-6">
                <span class={`h-px w-10 ${feature.theme === 'dark' ? 'bg-blue-500' : 'bg-blue-600'}`}></span>
                <span class={`text-sm font-bold uppercase tracking-widest ${feature.theme === 'dark' ? 'text-blue-400' : 'text-blue-600'}`}>
                  0{index + 1}
                </span>
              </div>
              
              <h2 class="text-3xl md:text-5xl font-bold font-heading mb-6 leading-tight">
                {feature.title}
              </h2>
              
              <p class={`text-lg mb-8 leading-relaxed ${feature.theme === 'dark' ? 'text-slate-400' : 'text-slate-600'}`}>
                {feature.description}
              </p>

              <ul class="space-y-4">
                {feature.points.map((point) => (
                  <li class="flex items-center gap-3">
                    <span class={`flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center ${feature.theme === 'dark' ? 'bg-blue-500/20 text-blue-400 ring-1 ring-blue-500/30' : 'bg-blue-100 text-blue-600'}`}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </span>
                    <span class={`font-medium text-lg ${feature.theme === 'dark' ? 'text-slate-300' : 'text-slate-700'}`}>{point}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </div>
      </section>
    ))}

    <!-- Gallery Section -->
    <section class="py-24 bg-slate-50 border-t border-slate-200">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="text-blue-600 text-sm font-bold tracking-widest uppercase mb-2 block">Visual Tour</span>
          <h2 class="text-4xl md:text-5xl font-bold font-heading text-slate-900 mb-4">
            Inside Our Training Infrastructure
          </h2>
          <div class="h-1 w-20 bg-blue-600 mx-auto rounded-full mb-6"></div>
          <p class="text-slate-600 text-lg">
            Explore the learning environments where students train with real tools, real systems, and real workflows.
          </p>
        </div>

        <ImageGallery client:load images={galleryImages} />
        
      </div>
    </section>

    <!-- CTA Section -->
    <div class="bg-white">
        <ContactCTA client:visible />
    </div>
  </main>

  <Footer client:visible />
</Layout>
