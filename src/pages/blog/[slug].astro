---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar";
import Footer from "../../components/Footer";
import BlogPost from "../../components/BlogPost";
import { supabase } from "../../lib/supabase";

const { slug } = Astro.params;

const { data: post, error } = await supabase
  .from('posts')
  .select('slug, title, excerpt, cover_image, author, publish_date, category, body, draft')
  .eq('slug', slug)
  .eq('draft', false)
  .maybeSingle();

if (error) {
  console.error('Failed to load post from Supabase:', error.message);
}

if (!post) {
  return new Response(null, { status: 404 });
}

const displayPost = {
  title: post.title,
  image: post.cover_image ?? '',
  author: post.author ?? 'Admin',
  date: post.publish_date ?? '',
  category: post.category ?? '',
};
---

<Layout
    title={`${post.title} | Logistics Gurukul Blog`}
    description={post.excerpt ?? ''}
>
    <Navbar client:load />
    <main>
        <BlogPost post={displayPost} client:load>
            <div class="blog-content" set:html={post.body ?? ''} />
        </BlogPost>
    </main>
    <Footer client:visible />
</Layout>
