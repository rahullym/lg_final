---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import BlogHero from "../components/BlogHero";
import BlogGrid from "../components/BlogGrid";
import { supabase } from "../lib/supabase";

const { data: rows, error } = await supabase
  .from('posts')
  .select('slug, title, excerpt, cover_image, author, publish_date, category')
  .eq('draft', false)
  .order('publish_date', { ascending: false, nullsFirst: false });

if (error) {
  console.error('Failed to load posts from Supabase:', error.message);
}

const serializedPosts = (rows ?? [])
  .map((p) => ({
    slug: p.slug,
    title: p.title,
    excerpt: p.excerpt ?? '',
    image: p.cover_image ?? '',
    author: p.author ?? 'Admin',
    date: p.publish_date ?? '',
    category: p.category ?? '',
    _ts: p.publish_date ? new Date(p.publish_date).getTime() : 0,
  }))
  .sort((a, b) => b._ts - a._ts)
  .map(({ _ts, ...rest }) => rest);
---

<Layout
    title="Logistics Career Guide | Study Tips & Job Trends"
    description="Your guide to a successful career in shipping. Articles on diploma courses, paid internships, and placement opportunities in Kochi and beyond."
>
    <Navbar client:load />
    <main>
        <BlogHero client:load />
        <BlogGrid client:load posts={serializedPosts} />
    </main>
    <Footer client:visible />
</Layout>
