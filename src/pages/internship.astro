---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import ContactCTA from "../components/ContactCTA";

const heroStats = [
    { value: "120", label: "Hours of Training" },
    { value: "4", label: "Learning Modules" },
    { value: "100%", label: "Industry Focused" },
    { value: "2026", label: "New Batch Open" },
];

const audience = [
    { title: "Commerce", desc: "Apply commerce fundamentals to real trade and logistics workflows." },
    { title: "BBA", desc: "Connect management theory with live operations and supply chain practice." },
    { title: "Economics", desc: "See trade, demand-supply, and global markets play out in real shipments." },
    { title: "Vocational Studies", desc: "Build hands-on, industry-relevant skills for the job market." },
];

const subjectLinks = [
    { subject: "Marketing", connection: "Distribution & Channel Management" },
    { subject: "Accounting", connection: "Costing, Freight Charges & Pricing" },
    { subject: "Economics", connection: "Trade, Demand-Supply, Global Markets" },
    { subject: "Business Studies", connection: "Operations & Supply Chain" },
];

const modules = [
    {
        step: "01",
        title: "Theoretical Learning",
        hours: "40 Hours",
        intro: "Build a strong foundation in how the logistics industry works, from core concepts to global trade practices.",
        label: "You will learn",
        items: [
            "Basics of Logistics & Supply Chain",
            "Export & Import Documentation",
            "Freight Operations (Air & Sea)",
            "Warehouse & Inventory Management",
            "Pricing & Quotation Techniques",
            "Incoterms & Trade Practices",
        ],
    },
    {
        step: "02",
        title: "Practical Sessions",
        hours: "40 Hours",
        intro: "Move from theory to practice with hands-on exercises designed around real shipment scenarios.",
        label: "Hands-on experience in",
        items: [
            "Shipment documentation preparation",
            "Invoice, Packing List, Bill of Lading (B/L), Airway Bill (AWB)",
            "Cost calculation and quotation",
            "Logistics software basics",
            "Case studies and real-life scenarios",
            "Working the way an industry professional does",
        ],
    },
    {
        step: "03",
        title: "Project Report",
        hours: "20 Hours",
        intro: "Turn what you've learned into a structured project that strengthens your academics and your resume.",
        label: "What you get",
        items: [
            "Guided real-world logistics scenarios",
            "Project aligned with your academic syllabus",
            "Report writing and presentation support",
            "Helps with internal marks and university submissions",
            "Resume building and industry awareness",
        ],
    },
    {
        step: "04",
        title: "Grooming, Software & AI",
        hours: "20 Hours",
        intro: "Walk out of the program job-ready — polished in communication, confident with tools, and familiar with the AI workflows shaping modern logistics.",
        label: "You will develop",
        items: [
            "Professional communication skills",
            "Grooming and workplace etiquette",
            "AI tools for business and logistics",
            "Excel and digital tools for the workplace",
            "The mindset to be job-ready, not just degree-ready",
        ],
    },
];

const benefits = [
    "Industry-relevant practical exposure",
    "Foundation in logistics and supply chain",
    "Certificate of Internship Completion",
    "Improved employability skills",
    "Real understanding of global trade",
    "Clear advantage for logistics careers",
];

const whoShouldEnroll = [
    { emoji: "🚀", text: "Explore career opportunities in logistics" },
    { emoji: "📘", text: "Gain practical knowledge beyond textbooks" },
    { emoji: "💼", text: "Build a strong resume and confidence" },
    { emoji: "🏆", text: "Prepare for industry placements" },
];
---

<Layout
    title="Logistics Internship Program in Kochi | 120-Hour Industry Training — Logistics Gurukul"
    description="Join Logistics Gurukul's 120-hour Internship Program in Kochi. 4 modules covering logistics, supply chain, documentation, AI tools, and real-world project work. 2026 batch now open for Commerce, BBA, Economics, and Vocational students."
>
    <Navbar client:load />

    <main>
        <!-- Hero Section -->
        <section
            class="relative min-h-[70vh] flex items-center bg-[#050505] overflow-hidden pt-28 pb-20 lg:pt-40 lg:pb-24"
        >
            <div class="absolute inset-0 z-0">
                <img
                    src="/port-img-scaled.jpg"
                    alt="Internship Program Background"
                    class="w-full h-full object-cover opacity-50"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/30"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-3xl">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-500/20 text-blue-300 border border-blue-400/30 text-xs font-bold tracking-widest uppercase mb-6">
                        Internship Program • 2026 Batch
                    </span>
                    <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight font-heading">
                        Internship <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-white">Program</span>
                    </h1>
                    <p class="text-lg md:text-xl text-slate-300 max-w-2xl leading-relaxed mb-10">
                        Jobs · Skills · Industry Exposure · Your Path Forward
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4">
                        <button
                            id="internship-hero-cta-enroll"
                            data-open-wizard
                            class="px-8 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2 shadow-lg shadow-blue-500/30"
                        >
                            Enroll Now
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                            </svg>
                        </button>
                        <a
                            id="internship-hero-cta-brochure"
                            href="#curriculum"
                            class="px-8 py-3 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-lg hover:bg-white/20 transition-colors border border-white/20 flex items-center justify-center gap-2"
                        >
                            View Curriculum
                        </a>
                    </div>
                </div>

                <!-- Hero Stats -->
                <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl">
                    {heroStats.map((s) => (
                        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
                            <div class="text-3xl md:text-4xl font-black text-white mb-1">{s.value}</div>
                            <div class="text-slate-400 text-xs font-medium uppercase tracking-widest">{s.label}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Why This Internship -->
        <section class="py-20 lg:py-24 bg-white">
            <div class="container mx-auto px-6">
                <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
                    <div>
                        <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                            The Opportunity
                        </span>
                        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 font-heading leading-tight">
                            Why This <span class="text-blue-600">Internship?</span>
                        </h2>
                        <p class="text-slate-600 text-lg leading-relaxed">
                            This internship is specially designed to bridge the gap between your academic syllabus and real industry practices. Instead of staying confined to textbooks, you step directly into how logistics businesses operate — observing, practicing, and building the kind of hands-on understanding that employers look for.
                        </p>
                    </div>

                    <div class="space-y-5">
                        <div class="flex gap-4 p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all">
                            <div class="w-12 h-12 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-900 text-lg mb-2">Understand how businesses actually operate</h3>
                                <p class="text-slate-600 leading-relaxed">Get a behind-the-scenes view of day-to-day logistics operations, decisions, and workflows.</p>
                            </div>
                        </div>
                        <div class="flex gap-4 p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all">
                            <div class="w-12 h-12 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-900 text-lg mb-2">Gain real-world skills beyond textbooks</h3>
                                <p class="text-slate-600 leading-relaxed">Work with documents, tools, and scenarios used every day in the global trade and supply chain industry.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Who It's For -->
        <section class="py-20 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-14">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                        Your Background Matters
                    </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-4 font-heading">
                        Perfect For Students Studying
                    </h2>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {audience.map((a, i) => (
                        <div class="group bg-white rounded-2xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:border-blue-100 hover:-translate-y-1 transition-all duration-300">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white font-black text-lg mb-5">
                                {String(i + 1).padStart(2, "0")}
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors">{a.title}</h3>
                            <p class="text-slate-600 text-sm leading-relaxed">{a.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Subject Connection -->
        <section class="py-20 lg:py-24 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-14">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                        Classroom Meets Industry
                    </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 font-heading leading-tight">
                        Logistics Connects Directly With <span class="text-blue-600">Your Subjects</span>
                    </h2>
                    <p class="text-slate-600 text-lg">
                        Whatever you're studying, logistics gives your syllabus a real-world dimension. Here's how it links up:
                    </p>
                </div>

                <div class="max-w-4xl mx-auto rounded-3xl overflow-hidden border border-slate-200 shadow-sm">
                    <div class="grid grid-cols-2 bg-slate-900 text-white">
                        <div class="px-6 py-4 font-bold text-sm uppercase tracking-widest">Your Subject</div>
                        <div class="px-6 py-4 font-bold text-sm uppercase tracking-widest border-l border-slate-700">Logistics Connection</div>
                    </div>
                    {subjectLinks.map((row, i) => (
                        <div class={`grid grid-cols-2 ${i % 2 === 0 ? "bg-white" : "bg-slate-50"}`}>
                            <div class="px-6 py-5 font-semibold text-slate-900">{row.subject}</div>
                            <div class="px-6 py-5 text-slate-700 border-l border-slate-200">{row.connection}</div>
                        </div>
                    ))}
                </div>

                <div class="max-w-3xl mx-auto mt-10 p-6 rounded-2xl bg-gradient-to-r from-blue-50 to-cyan-50 border border-blue-100 text-center">
                    <p class="text-lg md:text-xl text-slate-800 font-medium italic">
                        💡 You don't just study concepts — you see them in action.
                    </p>
                </div>
            </div>
        </section>

        <!-- Internship Structure -->
        <section id="curriculum" class="py-20 lg:py-24 bg-slate-900 relative overflow-hidden">
            <div class="absolute inset-0 opacity-20">
                <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
                <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-500/20 text-blue-300 border border-blue-400/30 text-xs font-bold tracking-widest uppercase mb-4">
                        The Structure
                    </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 font-heading">
                        Internship Structure
                    </h2>
                    <p class="text-slate-400 text-lg">
                        120 Hours Total · 4 Modules · Theory + Practical + Project + AI Tools
                    </p>
                </div>

                <!-- Module Overview Strip -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 max-w-5xl mx-auto">
                    {modules.map((m) => (
                        <div class="group bg-slate-800/60 backdrop-blur-sm border border-slate-700 rounded-2xl p-5 hover:border-blue-500/60 hover:bg-slate-800 transition-all">
                            <div class="text-blue-400 font-mono text-xs font-bold tracking-widest mb-2">MODULE {m.step}</div>
                            <div class="text-white font-bold text-base mb-3 leading-tight">{m.title}</div>
                            <div class="inline-block px-2.5 py-1 rounded-full bg-blue-500/20 text-blue-300 text-xs font-bold">{m.hours}</div>
                        </div>
                    ))}
                </div>

                <div class="text-center mb-16">
                    <div class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-blue-500 to-cyan-400 text-white font-bold text-base md:text-lg shadow-lg shadow-blue-500/30">
                        120 Hours of Structured, Industry-Aligned Learning
                    </div>
                </div>

                <!-- Detailed Modules -->
                <div class="space-y-6 max-w-5xl mx-auto">
                    {modules.map((m) => (
                        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-xl">
                            <div class="flex flex-col md:flex-row gap-6 md:items-start mb-6">
                                <div class="flex-shrink-0">
                                    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white font-black text-2xl shadow-lg shadow-blue-500/30">
                                        {m.step}
                                    </div>
                                </div>
                                <div class="flex-1">
                                    <div class="flex flex-wrap items-center gap-3 mb-3">
                                        <h3 class="text-2xl md:text-3xl font-bold text-slate-900 font-heading">Module {m.step} — {m.title}</h3>
                                        <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold">{m.hours}</span>
                                    </div>
                                    <p class="text-slate-600 leading-relaxed">{m.intro}</p>
                                </div>
                            </div>
                            <div class="md:pl-22 md:ml-6">
                                <div class="text-blue-600 font-bold text-xs uppercase tracking-widest mb-4">{m.label}</div>
                                <ul class="grid sm:grid-cols-2 gap-3">
                                    {m.items.map((it) => (
                                        <li class="flex items-start gap-3 text-slate-700">
                                            <span class="flex-shrink-0 w-5 h-5 mt-0.5 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center">
                                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                </svg>
                                            </span>
                                            <span class="leading-relaxed">{it}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Key Benefits -->
        <section class="py-20 lg:py-24 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-14">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                        What You Gain
                    </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-heading">
                        Key Benefits
                    </h2>
                </div>

                <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
                    {benefits.map((b) => (
                        <div class="flex items-center gap-4 p-5 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:bg-white hover:shadow-md transition-all">
                            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white shadow-md">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                            </span>
                            <span class="text-slate-800 font-medium">{b}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Who Should Enroll -->
        <section class="py-20 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto mb-14">
                    <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                        Is This For You?
                    </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-heading leading-tight">
                        Perfect For Students Who <span class="text-blue-600">Want To</span>
                    </h2>
                </div>

                <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-5">
                    {whoShouldEnroll.map((w) => (
                        <div class="flex items-center gap-5 p-6 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-lg hover:border-blue-100 transition-all">
                            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-100 flex items-center justify-center text-3xl shrink-0">
                                {w.emoji}
                            </div>
                            <p class="text-slate-800 font-semibold text-base md:text-lg">{w.text}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Certification -->
        <section class="py-20 lg:py-24 bg-white">
            <div class="container mx-auto px-6">
                <div class="max-w-5xl mx-auto">
                    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
                        <div>
                            <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-xs font-bold tracking-widest mb-4 uppercase">
                                Certification
                            </span>
                            <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 font-heading leading-tight">
                                What You'll <span class="text-blue-600">Earn</span>
                            </h2>
                            <p class="text-slate-600 text-lg leading-relaxed mb-4">
                                Every student who completes the program receives an <strong class="text-slate-900">Internship Completion Certificate</strong> from Logistics Gurukul.
                            </p>
                            <p class="text-slate-600 text-lg leading-relaxed">
                                Students opting for the full program with validated project work also receive a <strong class="text-slate-900">Course Certificate</strong> along with guided project report validation — useful for university submissions, resume credibility, and placement applications.
                            </p>
                        </div>

                        <div class="relative">
                            <div class="rounded-3xl bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 p-10 border border-slate-700 shadow-2xl">
                                <div class="flex items-center gap-3 mb-6">
                                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white shadow-lg shadow-blue-500/30">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                        </svg>
                                    </div>
                                    <div class="text-white font-bold text-xl">Logistics Gurukul</div>
                                </div>

                                <div class="text-blue-400 font-bold text-xs uppercase tracking-widest mb-2">Certificate Includes</div>
                                <ul class="space-y-3 text-slate-300">
                                    <li class="flex items-center gap-3">
                                        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                                        Internship Completion Certificate
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                                        Course Certificate (with full program)
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                                        Validated project report
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                                        Useful for university & placement applications
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="py-20 lg:py-24 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden">
            <div class="absolute inset-0 opacity-20">
                <div class="absolute top-1/4 left-1/3 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
                <div class="absolute bottom-1/4 right-1/3 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-3xl mx-auto text-center">
                    <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 font-heading leading-tight">
                        Ready to Start Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-white">Career?</span>
