---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import ShortTermCoursesComponent from "../components/ShortTermCourses";
const coursesListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Short-Term Logistics Courses",
    description:
        "3-month specialized diplomas in Warehouse, Shipping, Air Cargo, and Export-Import Management.",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Warehouse Operations Management",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "Shipping & Freight Forwarding",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: "Air Cargo Management",
        },
    ],
};
---

<Layout
    title="Short-Term Logistics Courses | 3-Month Fast Track Programs"
    description="Accelerate your career with 3-month specialized diplomas in Warehouse, Shipping, Air Cargo, and Export-Import Management."
    schema={coursesListSchema}
>
    <Navbar client:load />
    <main>
        <div class="pt-20">
            {/* Add padding top to account for fixed navbar */}
            <ShortTermCoursesComponent client:load />
        </div>
    </main>
    <Footer client:visible />
</Layout>
