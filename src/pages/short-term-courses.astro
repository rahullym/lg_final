---
import Layout from "../layouts/Layout.astro";
import { shortTermItemListSchema, shortTermBreadcrumbSchema } from '../schemas/shortTermCourses.js';
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import ShortTermCoursesComponent from "../components/ShortTermCourses";
---

<Layout
    title="Short-Term Logistics Courses in Kochi Kerala | 3-Month Diploma Programs"
    description="Accelerate your career with 3-month specialized diplomas in Warehouse, Shipping, Air Cargo, and Export-Import Management."
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(shortTermItemListSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(shortTermBreadcrumbSchema)} />
    </Fragment>
    <Navbar client:load />
    <main>
        <div class="pt-20">
            {/* Add padding top to account for fixed navbar */}
            <ShortTermCoursesComponent client:load />
        </div>
    </main>
    <Footer client:visible />
</Layout>
