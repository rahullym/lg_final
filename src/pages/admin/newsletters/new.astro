---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import NewsletterForm from '../../../components/admin/NewsletterForm.astro';

const err = new URL(Astro.request.url).searchParams.get('error');
---

<AdminShell title="New Newsletter" breadcrumbs={[{ label: 'Newsletters', href: '/admin/newsletters' }, { label: 'New' }]}>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-1">New Newsletter</h1>
    <p class="text-slate-600 text-sm mb-8">Upload a cover image and the newsletter PDF.</p>

    {err && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{err}</div>}

    <NewsletterForm action="/api/admin/newsletters" submitLabel="Create Newsletter" backHref="/admin/newsletters" method="create" />
  </div>
</AdminShell>
