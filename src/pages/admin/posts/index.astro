---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import { supabaseForUser } from '../../../lib/supabase';

const token = Astro.locals.accessToken!;
const client = supabaseForUser(token);
const { data: posts, error } = await client
  .from('posts')
  .select('id, slug, title, category, publish_date, draft, cover_image, updated_at')
  .order('updated_at', { ascending: false });

const params = new URL(Astro.request.url).searchParams;
const created = params.has('created');
const deleted = params.has('deleted');
const missing = params.has('missing');
---

<AdminShell title="Blog Posts" breadcrumbs={[{ label: 'Blog Posts' }]}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-1">Blog Posts</h1>
      <p class="text-slate-600 text-sm">Articles shown under Journal → Blogs on the public site.</p>
    </div>
    <div class="flex items-center gap-3">
      <button
        id="import-markdown-btn"
        type="button"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 font-semibold rounded-lg text-sm transition-colors"
        title="Migrate any existing markdown posts from src/content/posts into Supabase"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
        </svg>
        <span id="import-markdown-label">Import from markdown</span>
      </button>
      <a
        href="/admin/posts/new"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
        </svg>
        New Post
      </a>
    </div>
  </div>

  <script>
    const btn = document.getElementById('import-markdown-btn') as HTMLButtonElement | null;
    const label = document.getElementById('import-markdown-label');
    btn?.addEventListener('click', async () => {
      if (!btn || !label) return;
      btn.disabled = true;
      label.textContent = 'Importing…';
      try {
        const res = await fetch('/api/admin/migrate-posts', { method: 'POST' });
        const data = await res.json();
        if (!res.ok || data.ok === false) {
          const msg = data.failures?.map((f: { slug: string; message: string }) => `${f.slug}: ${f.message}`).join('\n') || data.error || 'Import failed';
          alert(`Import finished with issues:\n\n${msg}`);
        } else {
          alert(`Imported ${data.migrated} of ${data.total} posts.`);
        }
      } catch (err) {
        alert(`Import failed: ${err instanceof Error ? err.message : 'network error'}`);
      } finally {
        label.textContent = 'Import from markdown';
        btn.disabled = false;
        window.location.reload();
      }
    });
  </script>

  {created && (
    <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">
      Post created successfully.
    </div>
  )}

  {deleted && (
    <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">
      Post deleted.
    </div>
  )}

  {missing && (
    <div class="mb-6 p-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm font-semibold">
      That post no longer exists.
    </div>
  )}

  {error && (
    <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
      Failed to load posts: {error.message}
    </div>
  )}

  {!error && posts && posts.length === 0 && (
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
      <p class="text-slate-600 mb-4">No posts yet.</p>
      <a href="/admin/posts/new" class="inline-block px-5 py-2.5 bg-blue-600 text-white font-bold rounded-lg text-sm">Create your first post</a>
    </div>
  )}

  {!error && posts && posts.length > 0 && (
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr class="text-left text-slate-600 font-semibold uppercase text-xs tracking-wider">
            <th class="px-6 py-3">Title</th>
            <th class="px-6 py-3">Category</th>
            <th class="px-6 py-3">Date</th>
            <th class="px-6 py-3">Status</th>
            <th class="px-6 py-3 text-right">Updated</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {posts.map((p) => (
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4">
                <a href={`/admin/posts/${p.id}`} class="font-semibold text-slate-900 hover:text-blue-600">{p.title}</a>
                <div class="text-xs text-slate-500 mt-0.5">/{p.slug}</div>
              </td>
              <td class="px-6 py-4 text-slate-700">{p.category ?? '—'}</td>
              <td class="px-6 py-4 text-slate-700">{p.publish_date ?? '—'}</td>
              <td class="px-6 py-4">
                {p.draft ? (
                  <span class="inline-flex px-2.5 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-bold">Draft</span>
                ) : (
                  <span class="inline-flex px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold">Published</span>
                )}
              </td>
              <td class="px-6 py-4 text-right text-slate-500 text-xs">
                {new Date(p.updated_at).toLocaleDateString()}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminShell>
