---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';

const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
---

<AdminShell
  title="New Post"
  breadcrumbs={[{ label: 'Blog Posts', href: '/admin/posts' }, { label: 'New' }]}
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-1">New Blog Post</h1>
    <p class="text-slate-600 text-sm mb-8">Fill in the fields below. You can save as Draft and publish later.</p>

    {error && (
      <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{error}</div>
    )}

    <form
      method="POST"
      action="/api/admin/posts"
      enctype="multipart/form-data"
      class="bg-white rounded-2xl border border-slate-200 p-8 space-y-6"
    >
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="title">Title *</label>
        <input
          id="title"
          name="title"
          type="text"
          required
          maxlength="200"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="slug">Slug</label>
        <input
          id="slug"
          name="slug"
          type="text"
          placeholder="auto-generated from title"
          pattern="[a-z0-9-]*"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 font-mono"
        />
        <p class="text-xs text-slate-500 mt-1">Lowercase letters, numbers, and hyphens only. Leave blank to auto-generate.</p>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="excerpt">Excerpt</label>
        <textarea
          id="excerpt"
          name="excerpt"
          rows="2"
          maxlength="500"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          placeholder="Short summary for SEO and previews"
        ></textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="cover_image_file">Cover Image</label>
        <input
          id="cover_image_file"
          name="cover_image_file"
          type="file"
          accept="image/*"
          class="block w-full text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
        />
        <p class="text-xs text-slate-500 mt-1">Optional. Uploaded to Supabase Storage.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="author">Author</label>
          <input
            id="author"
            name="author"
            type="text"
            value="Admin"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          />
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="publish_date">Publish Date</label>
          <input
            id="publish_date"
            name="publish_date"
            type="text"
            placeholder="March 30, 2026"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="category">Category</label>
        <input
          id="category"
          name="category"
          type="text"
          placeholder="e.g. Career, Industry, Tips"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="body">Body (Markdown)</label>
        <textarea
          id="body"
          name="body"
          rows="18"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm font-mono focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
          placeholder={`# Heading\n\nWrite your post in markdown.\n\n**bold**, *italic*, [links](https://example.com), and images work.`}
        ></textarea>
      </div>

      <div class="flex items-center gap-3 p-4 rounded-lg bg-slate-50 border border-slate-200">
        <input id="draft" name="draft" type="checkbox" class="w-4 h-4" />
        <label for="draft" class="text-sm font-semibold text-slate-700">Save as draft (not publicly visible)</label>
      </div>

      <div class="flex items-center justify-between pt-2 border-t border-slate-100">
        <a href="/admin/posts" class="text-sm text-slate-600 hover:text-slate-900 font-semibold">Cancel</a>
        <button
          type="submit"
          class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors"
        >
          Create Post
        </button>
      </div>
    </form>

    <script>
      // Auto-fill slug from title when the slug field is empty/untouched.
      const titleEl = document.getElementById('title') as HTMLInputElement | null;
      const slugEl = document.getElementById('slug') as HTMLInputElement | null;
      let touched = false;
      slugEl?.addEventListener('input', () => { touched = true; });
      titleEl?.addEventListener('input', () => {
        if (touched || !slugEl) return;
        slugEl.value = titleEl.value
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '');
      });
    </script>
  </div>
</AdminShell>
