---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user!;

const collections = [
  { key: 'posts', label: 'Blog Posts', desc: 'Articles shown under Journal → Blogs.' },
  { key: 'celebrations', label: 'Celebrations', desc: 'Life @ Gurukul — Celebrations page entries.' },
  { key: 'seminars', label: 'Seminars & Events', desc: 'Life @ Gurukul — Seminars page entries.' },
  { key: 'newsletters', label: 'Newsletters', desc: 'PDF newsletter editions shown under Journal → Newsletter.' },
  { key: 'infrastructure-gallery', label: 'Infrastructure Gallery', desc: 'Campus photos shown in the Infrastructure gallery.' },
];
---

<Layout title="Admin Dashboard | Logistics Gurukul">
  <main class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-blue-600 font-black tracking-tight">Logistics Gurukul</span>
          <span class="text-slate-300">/</span>
          <span class="text-slate-700 font-semibold">Admin</span>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <span class="text-slate-500">{user.email}</span>
          <form method="POST" action="/api/admin/logout">
            <button type="submit" class="px-3 py-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-100 transition-colors text-sm font-semibold">
              Sign out
            </button>
          </form>
        </div>
      </div>
    </header>

    <div class="container mx-auto px-6 py-10">
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Content</h1>
      <p class="text-slate-600 mb-8">Choose a collection to manage its entries.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {collections.map((c) => (
          <a
            href={`/admin/${c.key}`}
            class="group block p-6 bg-white rounded-2xl border border-slate-200 hover:border-blue-300 hover:shadow-md transition-all"
          >
            <h2 class="text-lg font-bold text-slate-900 group-hover:text-blue-700 transition-colors mb-1.5">{c.label}</h2>
            <p class="text-sm text-slate-600 leading-relaxed">{c.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
