---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import EventForm from '../../../components/admin/EventForm.astro';

const err = new URL(Astro.request.url).searchParams.get('error');
---

<AdminShell title="New Celebration" breadcrumbs={[{ label: 'Celebrations', href: '/admin/celebrations' }, { label: 'New' }]}>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-1">New Celebration</h1>
    <p class="text-slate-600 text-sm mb-8">Add a new event folder. You can upload multiple gallery photos at once.</p>

    {err && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{err}</div>}

    <EventForm action="/api/admin/celebrations" submitLabel="Create Celebration" backHref="/admin/celebrations" method="create" />
  </div>
</AdminShell>
