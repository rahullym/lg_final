---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import { supabaseForUser } from '../../../lib/supabase';
import { listEvents } from '../../../lib/eventCollection';

const client = supabaseForUser(Astro.locals.accessToken!);
const { data: items, error } = await listEvents(client, 'celebrations');

const params = new URL(Astro.request.url).searchParams;
const created = params.has('created');
const deleted = params.has('deleted');
const missing = params.has('missing');
---

<AdminShell title="Celebrations" breadcrumbs={[{ label: 'Celebrations' }]}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-1">Celebrations</h1>
      <p class="text-slate-600 text-sm">Events grouped by folder — each celebration has its own cover and gallery of photos.</p>
    </div>
    <div class="flex items-center gap-3">
      <button id="import-btn" type="button"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 font-semibold rounded-lg text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
        </svg>
        <span id="import-label">Import from existing</span>
      </button>
      <a href="/admin/celebrations/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
        </svg>
        New Celebration
      </a>
    </div>
  </div>

  {created && <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">Celebration created.</div>}
  {deleted && <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">Celebration deleted.</div>}
  {missing && <div class="mb-6 p-4 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm font-semibold">That celebration no longer exists.</div>}
  {error && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">Failed to load: {error.message}</div>}

  {!error && items && items.length === 0 && (
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
      <p class="text-slate-600 mb-4">No celebrations yet.</p>
      <a href="/admin/celebrations/new" class="inline-block px-5 py-2.5 bg-blue-600 text-white font-bold rounded-lg text-sm">Create your first celebration</a>
    </div>
  )}

  {!error && items && items.length > 0 && (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {items.map((it) => {
        const count = Array.isArray(it.gallery) ? it.gallery.length : 0;
        return (
          <a href={`/admin/celebrations/${it.id}`}
             class="group block bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-blue-300 hover:shadow-md transition-all">
            <div class="aspect-video bg-slate-100 overflow-hidden relative">
              {it.cover ? (
                <img src={it.cover} alt={it.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-slate-400 text-sm">No cover</div>
              )}
              {it.draft && (
                <span class="absolute top-2 left-2 inline-flex px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-bold">Draft</span>
              )}
              <span class="absolute bottom-2 right-2 inline-flex items-center gap-1 px-2 py-1 rounded-full bg-black/60 text-white text-xs font-bold backdrop-blur-sm">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                {count}
              </span>
            </div>
            <div class="p-4">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xs font-bold text-blue-600 uppercase tracking-widest">{it.year}</span>
                {it.order > 0 && <span class="text-xs text-slate-400">Order {it.order}</span>}
              </div>
              <h3 class="text-base font-bold text-slate-900 group-hover:text-blue-700 transition-colors line-clamp-2">{it.title}</h3>
            </div>
          </a>
        );
      })}
    </div>
  )}

  <script>
    const btn = document.getElementById('import-btn') as HTMLButtonElement | null;
    const label = document.getElementById('import-label');
    btn?.addEventListener('click', async () => {
      if (!btn || !label) return;
      btn.disabled = true;
      label.textContent = 'Importing…';
      try {
        const res = await fetch('/api/admin/migrate-celebrations', { method: 'POST' });
        const data = await res.json();
        if (!res.ok || data.ok === false) {
          const msg = data.failures?.map((f: { slug: string; message: string }) => `${f.slug}: ${f.message}`).join('\n') || data.error || 'Import failed';
          alert(`Import finished with issues:\n\n${msg}`);
        } else {
          alert(`Imported ${data.migrated} of ${data.total}.`);
        }
      } catch (err) {
        alert(`Import failed: ${err instanceof Error ? err.message : 'network error'}`);
      } finally {
        label.textContent = 'Import from existing';
        btn.disabled = false;
        window.location.reload();
      }
    });
  </script>
</AdminShell>
