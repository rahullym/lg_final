---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';

const err = new URL(Astro.request.url).searchParams.get('error');
---

<AdminShell
  title="Upload Image"
  breadcrumbs={[{ label: 'Infrastructure Gallery', href: '/admin/infrastructure-gallery' }, { label: 'Upload' }]}
>
  <div class="max-w-xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-1">Upload Image</h1>
    <p class="text-slate-600 text-sm mb-8">Add a new photo to the Infrastructure gallery.</p>

    {err && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{err}</div>}

    <form method="POST" action="/api/admin/infrastructure-gallery" enctype="multipart/form-data"
          class="bg-white rounded-2xl border border-slate-200 p-8 space-y-6">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="image_file">Image *</label>
        <input id="image_file" name="image_file" type="file" accept="image/*" required
          class="block w-full text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
        <p class="text-xs text-slate-500 mt-1">JPG, PNG, or WebP. Uploaded to Supabase Storage.</p>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="alt">Alt Text *</label>
        <input id="alt" name="alt" type="text" required maxlength="200"
          placeholder="e.g. Campus Facility 12"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
        <p class="text-xs text-slate-500 mt-1">Short description for screen readers and SEO.</p>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="order">Display Order</label>
        <input id="order" name="order" type="number" value="0"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
        <p class="text-xs text-slate-500 mt-1">Lower numbers appear first. Default 0.</p>
      </div>

      <div class="flex items-center justify-between pt-2 border-t border-slate-100">
        <a href="/admin/infrastructure-gallery" class="text-sm text-slate-600 hover:text-slate-900 font-semibold">Cancel</a>
        <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors">Upload</button>
      </div>
    </form>
  </div>
</AdminShell>
