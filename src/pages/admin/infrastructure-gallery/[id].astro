---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import { supabaseForUser } from '../../../lib/supabase';

const id = Astro.params.id!;
const client = supabaseForUser(Astro.locals.accessToken!);
const { data: item, error } = await client
  .from('infrastructure_gallery')
  .select('*')
  .eq('id', id)
  .single();

if (error || !item) {
  return Astro.redirect('/admin/infrastructure-gallery?missing=1');
}

const params = new URL(Astro.request.url).searchParams;
const saved = params.has('saved');
const err = params.get('error');
---

<AdminShell
  title={`Edit: ${item.alt}`}
  breadcrumbs={[{ label: 'Infrastructure Gallery', href: '/admin/infrastructure-gallery' }, { label: 'Edit' }]}
>
  <div class="max-w-xl mx-auto">
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 mb-1">Edit Image</h1>
      </div>
      <form method="POST" action={`/api/admin/infrastructure-gallery/${item.id}`} onsubmit="return confirm('Delete this image?');">
        <input type="hidden" name="_method" value="DELETE" />
        <button type="submit" class="px-4 py-2 bg-white hover:bg-red-50 text-red-600 border border-red-200 font-semibold rounded-lg text-sm transition-colors">Delete</button>
      </form>
    </div>

    {saved && <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">Saved.</div>}
    {err && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">{err}</div>}

    <form method="POST" action={`/api/admin/infrastructure-gallery/${item.id}`} enctype="multipart/form-data"
          class="bg-white rounded-2xl border border-slate-200 p-8 space-y-6">
      <input type="hidden" name="_method" value="PATCH" />
      <input type="hidden" name="image" value={item.image} />

      <div>
        <div class="text-sm font-semibold text-slate-700 mb-2">Current image</div>
        <img src={item.image} alt={item.alt} class="w-full max-h-64 object-contain rounded-lg border border-slate-200 bg-slate-50" />
        <p class="text-xs text-slate-500 mt-1 font-mono break-all">{item.image}</p>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="image_file">Replace image (optional)</label>
        <input id="image_file" name="image_file" type="file" accept="image/*"
          class="block w-full text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="alt">Alt Text *</label>
        <input id="alt" name="alt" type="text" required maxlength="200" value={item.alt}
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="order">Display Order</label>
        <input id="order" name="order" type="number" value={item.order}
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
      </div>

      <div class="flex items-center justify-between pt-2 border-t border-slate-100">
        <a href="/admin/infrastructure-gallery" class="text-sm text-slate-600 hover:text-slate-900 font-semibold">Back to list</a>
        <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors">Save Changes</button>
      </div>
    </form>
  </div>
</AdminShell>
