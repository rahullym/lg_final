---
export const prerender = false;

import AdminShell from '../../../components/admin/AdminShell.astro';
import { supabaseForUser } from '../../../lib/supabase';

const client = supabaseForUser(Astro.locals.accessToken!);
const { data: items, error } = await client
  .from('infrastructure_gallery')
  .select('id, alt, image, "order", created_at')
  .order('order', { ascending: true })
  .order('created_at', { ascending: true });

const params = new URL(Astro.request.url).searchParams;
const created = params.has('created');
const deleted = params.has('deleted');
---

<AdminShell title="Infrastructure Gallery" breadcrumbs={[{ label: 'Infrastructure Gallery' }]}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-1">Infrastructure Gallery</h1>
      <p class="text-slate-600 text-sm">Campus photos shown on the Infrastructure page.</p>
    </div>
    <div class="flex items-center gap-3">
      <button
        id="import-gallery-btn"
        type="button"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 font-semibold rounded-lg text-sm transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
        </svg>
        <span id="import-gallery-label">Import from existing</span>
      </button>
      <a href="/admin/infrastructure-gallery/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
        </svg>
        Upload Image
      </a>
    </div>
  </div>

  {created && <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">Image added.</div>}
  {deleted && <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-semibold">Image deleted.</div>}
  {error && <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">Failed to load: {error.message}</div>}

  {!error && items && items.length === 0 && (
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
      <p class="text-slate-600 mb-4">No images yet.</p>
      <a href="/admin/infrastructure-gallery/new" class="inline-block px-5 py-2.5 bg-blue-600 text-white font-bold rounded-lg text-sm">Upload your first image</a>
    </div>
  )}

  {!error && items && items.length > 0 && (
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {items.map((it) => (
        <a href={`/admin/infrastructure-gallery/${it.id}`} class="group block bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-blue-300 hover:shadow-md transition-all">
          <div class="aspect-square bg-slate-100 overflow-hidden">
            <img src={it.image} alt={it.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
          </div>
          <div class="p-3">
            <div class="text-sm font-semibold text-slate-900 group-hover:text-blue-700 transition-colors line-clamp-2">{it.alt}</div>
            <div class="text-xs text-slate-500 mt-1">Order: {it.order}</div>
          </div>
        </a>
      ))}
    </div>
  )}

  <script>
    const btn = document.getElementById('import-gallery-btn') as HTMLButtonElement | null;
    const label = document.getElementById('import-gallery-label');
    btn?.addEventListener('click', async () => {
      if (!btn || !label) return;
      btn.disabled = true;
      label.textContent = 'Importing…';
      try {
        const res = await fetch('/api/admin/migrate-gallery', { method: 'POST' });
        const data = await res.json();
        if (!res.ok || data.ok === false) {
          const msg = data.failures?.map((f: { id: string; message: string }) => `${f.id}: ${f.message}`).join('\n') || data.error || 'Import failed';
          alert(`Import finished with issues:\n\n${msg}`);
        } else {
          alert(`Imported ${data.migrated} images. Skipped ${data.skipped} already present.`);
        }
      } catch (err) {
        alert(`Import failed: ${err instanceof Error ? err.message : 'network error'}`);
      } finally {
        label.textContent = 'Import from existing';
        btn.disabled = false;
        window.location.reload();
      }
    });
  </script>
</AdminShell>
