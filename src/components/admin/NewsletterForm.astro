---
interface Props {
  action: string;
  submitLabel: string;
  backHref: string;
  method?: 'create' | 'edit';
  defaults?: {
    title?: string;
    slug?: string;
    cover?: string | null;
    pdf?: string | null;
    issueDate?: string | null;
    description?: string;
    draft?: boolean;
  };
}

const { action, submitLabel, backHref, method = 'create', defaults = {} } = Astro.props;
---

<form
  method="POST"
  action={action}
  enctype="multipart/form-data"
  class="bg-white rounded-2xl border border-slate-200 p-8 space-y-6"
>
  {method === 'edit' && <input type="hidden" name="_method" value="PATCH" />}
  <input type="hidden" name="cover" value={defaults.cover ?? ''} />
  <input type="hidden" name="pdf" value={defaults.pdf ?? ''} />

  <div class="grid sm:grid-cols-2 gap-6">
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="title">Title *</label>
      <input
        id="title" name="title" type="text" required maxlength="200" value={defaults.title ?? ''}
        placeholder="e.g. AIYER LENS — March 30 Edition"
        class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
      />
    </div>
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="issue_date">Issue Date</label>
      <input
        id="issue_date" name="issue_date" type="date" value={defaults.issueDate ?? ''}
        class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
      />
    </div>
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="slug">Slug</label>
    <input
      id="slug" name="slug" type="text" pattern="[a-z0-9-]*" value={defaults.slug ?? ''}
      placeholder="auto-generated from title"
      class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 font-mono"
    />
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5" for="description">Short description</label>
    <textarea
      id="description" name="description" rows="2" maxlength="280"
      placeholder="Optional one-liner shown beneath the cover."
      class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
    >{defaults.description ?? ''}</textarea>
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Cover image</label>
    {defaults.cover && (
      <div class="mb-3">
        <img src={defaults.cover} alt="current cover" class="h-32 w-auto rounded-lg border border-slate-200" />
        <p class="text-xs text-slate-500 mt-1 font-mono break-all">{defaults.cover}</p>
      </div>
    )}
    <input
      name="cover_file" type="file" accept="image/*"
      class="block w-full text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
    />
    <p class="text-xs text-slate-500 mt-1">
      {method === 'edit' ? 'Optional — pick a new image to replace the current cover.' : 'Optional thumbnail shown on the public newsletter grid.'}
    </p>
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5">PDF file {method === 'create' && <span>*</span>}</label>
    {defaults.pdf && (
      <div class="mb-3">
        <a href={defaults.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 border border-slate-200 text-slate-700 font-semibold text-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          View current PDF
        </a>
        <p class="text-xs text-slate-500 mt-1 font-mono break-all">{defaults.pdf}</p>
      </div>
    )}
    <input
      name="pdf_file" type="file" accept="application/pdf"
      required={method === 'create' && !defaults.pdf}
      class="block w-full text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
    />
    <p class="text-xs text-slate-500 mt-1">
      {method === 'edit' ? 'Optional — pick a new PDF to replace the current one.' : 'The PDF visitors will download via "View PDF".'}
    </p>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <input id="draft" name="draft" type="checkbox" checked={defaults.draft ?? false} class="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
    <label for="draft" class="text-sm text-slate-700 font-semibold">Save as draft (hide from public site)</label>
  </div>

  <div class="flex items-center justify-between pt-2 border-t border-slate-100">
    <a href={backHref} class="text-sm text-slate-600 hover:text-slate-900 font-semibold">Cancel</a>
    <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-colors">
      {submitLabel}
    </button>
  </div>
</form>

<script>
  const titleEl = document.getElementById('title') as HTMLInputElement | null;
  const slugEl = document.getElementById('slug') as HTMLInputElement | null;
  let touched = !!(slugEl?.value);
  slugEl?.addEventListener('input', () => { touched = true; });
  titleEl?.addEventListener('input', () => {
    if (touched || !slugEl) return;
    slugEl.value = titleEl.value
      .toLowerCase().trim()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  });
</script>
