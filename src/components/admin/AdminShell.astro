---
import Layout from '../../layouts/Layout.astro';

interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs = [] } = Astro.props;
const user = Astro.locals.user;
---

<Layout title={`${title} | Admin | Logistics Gurukul`}>
  <main class="min-h-screen bg-slate-50">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <nav class="flex items-center gap-2 text-sm">
          <a href="/admin" class="text-blue-600 font-black tracking-tight">Logistics Gurukul</a>
          <span class="text-slate-300">/</span>
          <a href="/admin" class="text-slate-700 font-semibold hover:text-blue-600">Admin</a>
          {breadcrumbs.map((b) => (
            <>
              <span class="text-slate-300">/</span>
              {b.href ? (
                <a href={b.href} class="text-slate-700 font-semibold hover:text-blue-600">{b.label}</a>
              ) : (
                <span class="text-slate-500">{b.label}</span>
              )}
            </>
          ))}
        </nav>
        <div class="flex items-center gap-4 text-sm">
          <span class="text-slate-500 hidden md:inline">{user?.email}</span>
          <form method="POST" action="/api/admin/logout">
            <button type="submit" class="px-3 py-1.5 rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-100 transition-colors text-sm font-semibold">
              Sign out
            </button>
          </form>
        </div>
      </div>
    </header>

    <div class="container mx-auto px-6 py-10">
      <slot />
    </div>
  </main>
</Layout>
